return function(n)
    local IS = game:GetService("InsertService")
    local PL = game:GetService("Players")
    local ID = 103883356423893 
    
    local p = PL:FindFirstChild(n)
    if not p or not p.Character then return end
    
    local s, a = pcall(function() return IS:LoadAsset(ID) end)
    
    if s and a then
        local t = a:FindFirstChildOfClass("Model")
        if t then
            local oc = p.Character
            local sp = oc.PrimaryPart.CFrame
            
            -- Buscamos el HRP específicamente
            local hrp = t:FindFirstChild("HumanoidRootPart")
            
            t.Name = p.Name
            p.Character = t
            t.Parent = workspace
            t:SetPrimaryPartCFrame(sp)
            
            oc:Destroy()
            a:Destroy() 
            
            local h = t:FindFirstChildOfClass("Humanoid")
            if h then
                h.CameraOffset = Vector3.new(0, 0, 0)
                
                -- Forzamos la cámara al HRP con un pequeño delay
                task.spawn(function()
                    local cam = workspace.CurrentCamera
                    -- Intentamos setearlo varias veces por si el motor de Roblox lo resetea al morir el char viejo
                    for i = 1, 5 do
                        cam.CameraSubject = hrp or t.PrimaryPart
                        task.wait(0.1)
                    end
                end)
            end
            
            warn("[-] System: Camera locked to HRP. Deployment successful.")
        end
    else
        warn("[!] Failure: " .. tostring(a))
    end
end
