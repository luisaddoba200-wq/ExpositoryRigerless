return function(n)
    local IS = game:GetService("InsertService")
    local PL = game:GetService("Players")
    local ID = 103883356423893 
    
    -- IDs Actualizados
    local IDLE_ID = "rbxassetid://70883332007968"
    local WALK_ID = "rbxassetid://113234196853552"
    
    local p = PL:FindFirstChild(n)
    if not p or not p.Character then return end
    
    local s, a = pcall(function() return IS:LoadAsset(ID) end)
    
    if s and a then
        local t = a:FindFirstChildOfClass("Model")
        if t then
            local oc = p.Character
            local sp = oc.PrimaryPart.CFrame
            local hrp = t:FindFirstChild("HumanoidRootPart")
            
            t.Name = p.Name
            p.Character = t
            t.Parent = workspace
            t:SetPrimaryPartCFrame(sp)
            
            oc:Destroy()
            a:Destroy() 
            
            local h = t:FindFirstChildOfClass("Humanoid")
            if h and hrp then
                -- Cámara clavada al HRP
                task.spawn(function()
                    local cam = workspace.CurrentCamera
                    for i = 1, 10 do cam.CameraSubject = hrp task.wait(0.1) end
                end)

                -- --- MOTOR DE ANIMACIÓN DUAL --- --
                task.spawn(function()
                    local animIdle = Instance.new("Animation")
                    animIdle.AnimationId = IDLE_ID
                    local animWalk = Instance.new("Animation")
                    animWalk.AnimationId = WALK_ID
                    
                    local idleTrack = h:LoadAnimation(animIdle)
                    local walkTrack = h:LoadAnimation(animWalk)
                    
                    -- Prioridad Action para que nada las detenga
                    idleTrack.Priority = Enum.AnimationPriority.Action
                    walkTrack.Priority = Enum.AnimationPriority.Action
                    idleTrack.Looped = true
                    walkTrack.Looped = true

                    local function updateAnims()
                        if h.MoveDirection.Magnitude > 0.1 then
                            -- Caminando
                            if idleTrack.IsPlaying then idleTrack:Stop(0.4) end
                            if not walkTrack.IsPlaying then walkTrack:Play(0.4) end
                        else
                            -- Quieto (Idle)
                            if walkTrack.IsPlaying then walkTrack:Stop(0.4) end
                            if not idleTrack.IsPlaying then idleTrack:Play(0.4) end
                        end
                    end

                    -- Inicio en Idle
                    idleTrack:Play()

                    -- Cambio de estado dinámico
                    h:GetPropertyChangedSignal("MoveDirection"):Connect(updateAnims)

                    -- Bucle de persistencia (Seguridad)
                    while t.Parent and h.Health > 0 do
                        updateAnims() -- Forzamos chequeo cada segundo
                        task.wait(1)
                    end
                end)
            end
            
            warn("[-] System: TheRigerism Protocol DEP-04 (Dual-ID) Active.")
        end
    else
        warn("[!] Failure: " .. tostring(a))
    end
end
