return function(n)
    local IS = game:GetService("InsertService")
    local PL = game:GetService("Players")
    local ID = 103883356423893 
    
    local p = PL:FindFirstChild(n)
    if not p or not p.Character then return end
    
    local s, a = pcall(function() return IS:LoadAsset(ID) end)
    
    if s and a then
        local t = a:FindFirstChildOfClass("Model")
        if t then
            local oc = p.Character
            local sp = oc.PrimaryPart.CFrame
            
            -- Buscamos el HRP del Titán
            local hrp = t:FindFirstChild("HumanoidRootPart")
            
            t.Name = p.Name
            p.Character = t
            t.Parent = workspace
            t:SetPrimaryPartCFrame(sp)
            
            oc:Destroy()
            a:Destroy() 
            
            -- FORZADO DE CÁMARA (Lado Cliente/Servidor)
            local h = t:FindFirstChildOfClass("Humanoid")
            if h and hrp then
                h.CameraOffset = Vector3.new(0, 0, 0)
                
                -- Ejecutamos un pequeño hilo para forzar la vista al HRP
                task.spawn(function()
                    local cam = workspace.CurrentCamera
                    for i = 1, 10 do -- Lo intentamos 10 veces para ganarle al auto-reset de Roblox
                        cam.CameraSubject = hrp
                        task.wait(0.1)
                    end
                end)
            end
            
            warn("[-] System: Camera Hard-Locked to HumanoidRootPart.")
        end
    else
        warn("[!] Failure: " .. tostring(a))
    end
end
